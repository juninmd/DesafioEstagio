# DesafioEstagio - Environment Configuration
# Copy this file to .env and fill in the values.
#
# WARNING: Never commit the actual .env file to version control.
# It contains sensitive credentials and is excluded via .gitignore.

# Build Configuration
BUILD_CONFIGURATION=Release
TARGET_FRAMEWORK=v4.6.1

# Deployment
DEPLOY_TARGET=staging
DEPLOY_TIMEOUT_SECONDS=300

# Health Check
HEALTH_CHECK_ENDPOINT=http://localhost:5000/health
HEALTH_CHECK_TIMEOUT_SECONDS=30

# Notifications -- set via GitHub Secrets in production
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#deployments

# Monitoring -- set via GitHub Secrets in production
SENTRY_DSN=
APPLICATION_INSIGHTS_KEY=

# Security -- set via GitHub Secrets in production
SNYK_TOKEN=
